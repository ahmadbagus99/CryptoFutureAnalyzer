AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Crypto futures — analisis kline (app ini)
# Sumber: auto | cryptocompare | okx | bybit | binance
# cryptocompare = domain lain (sering bisa saat bursa diblokir); data spot, bukan futures perps
FUTURES_DATA_PROVIDER=auto
# Tanpa binance di akhir — jika semua gagal, pesan error tidak menyalahkan hanya Binance (tambahkan binance jika jaringanmu bisa)
FUTURES_AUTO_ORDER=cryptocompare,okx,bybit
SCAN_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,NOMUSDT

BYBIT_API_BASE=https://api.bybit.com
OKX_API_BASE=https://www.okx.com
BINANCE_FUTURES_BASE=https://fapi.binance.com

# Jika koneksi ke bursa gagal: aktifkan VPN/proxy lalu set port proxy lokal, contoh:
# CRYPTO_HTTP_PROXY=http://127.0.0.1:7890
CRYPTO_HTTP_PROXY=
BINANCE_HTTP_PROXY=

CRYPTO_HTTP_TIMEOUT=12
CRYPTO_HTTP_CONNECT_TIMEOUT=6
ANALYSIS_MAX_SECONDS=120
CHART_POLL_SECONDS=15
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=350
ANTHROPIC_TIMEOUT=20
